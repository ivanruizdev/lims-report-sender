# =================================================================
# LIMS-Bridge - Configuration Template
# =================================================================
# Instructions: Copy this file and rename it to ".env", then fill in the values.
# IMPORTANT: Never commit the real ".env" file to public repositories.

# -----------------------------------------------------------------
# 1. Database Configuration (LIMS Postgres)
# -----------------------------------------------------------------
# The IP or hostname of your local LIMS database
DB_HOST=192.168.1.XX
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=postgres_user
DB_PASSWORD=your_secure_password

# -----------------------------------------------------------------
# 2. Telegram Bot API Configuration
# -----------------------------------------------------------------
# Obtain this token from @BotFather on Telegram
TELEGRAM_TOKEN=123456789:ABCDefghIJKLmnopQRSTuvwxYZ

# -----------------------------------------------------------------
# 3. WhatsApp Cloud API Configuration (Meta)
# -----------------------------------------------------------------
# Permanent access token from the Meta for Developers App
WHATSAPP_TOKEN=EAAB...your_full_token

# Phone Number ID (different from the phone number itself)
WHATSAPP_PHONE_ID=105...your_phone_id

# (Optional) WhatsApp Business Account ID
WHATSAPP_BUSINESS_ID=209...your_business_id

# -----------------------------------------------------------------
# 4. System and Path Configuration
# -----------------------------------------------------------------
# Absolute path inside the container where the bot watches for PDFs
WATCH_PATH=/app/reports/pdf_output

# Port where the React Dashboard will run
DASHBOARD_PORT=8080

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# -----------------------------------------------------------------
# 5. Interface Security (Optional)
# -----------------------------------------------------------------
# Define credentials to access the Dashboard UI
ADMIN_USER=admin
ADMIN_PASS=changeme123
